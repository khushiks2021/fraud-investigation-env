 # Get a free key at https://console.groq.com
  GROQ_API_KEY=your_groq_key_here

  # Or use HuggingFace token (takes priority over GROQ)
  HF_TOKEN=

  # Environment URL (default works with docker-compose)
  ENV_URL=http://localhost:8000

  # Model (llama-3.1-8b-instant is fastest on Groq free tier)
  MODEL_NAME=llama-3.1-8b-instant

  # Episodes per task (2 = recommended for Groq free tier)
  EPISODES_PER_TASK=2
